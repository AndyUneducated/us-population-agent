# Copy to secrets.toml for local Streamlit testing (never commit secrets.toml).
# On Streamlit Community Cloud: paste the same keys into App → Settings → Secrets.

# --- Required for cloud deploy (Snowflake live data) ---
DATA_BACKEND = "snowflake"
CENSUS_YEAR = "2020"

SNOWFLAKE_ACCOUNT = "YOUR_ACCOUNT_ID"
SNOWFLAKE_USER = "YOUR_USERNAME"
SNOWFLAKE_PASSWORD = "YOUR_PAT_OR_PASSWORD"
SNOWFLAKE_ROLE = "ACCOUNTADMIN"
SNOWFLAKE_WAREHOUSE = "COMPUTE_WH"
SNOWFLAKE_DATABASE = "US_OPEN_CENSUS_DATA__NEIGHBORHOOD_INSIGHTS__FREE_DATASET"
SNOWFLAKE_SCHEMA = "PUBLIC"

# --- LLM (Gemini free tier) ---
LLM_PROVIDER = "gemini"
GEMINI_API_KEY = "YOUR_GEMINI_API_KEY"
GEMINI_MODEL = "gemini-flash-lite-latest"

# --- Optional ---
# QUERY_TIMEOUT_SECONDS = "30"
# SQL_ROW_LIMIT = "100"
