# Snowflake connection (copy to .env and fill in secrets locally — never commit .env)

# Account identifier from Snowflake UI (Profile → Account)
SNOWFLAKE_ACCOUNT=EXLVOFZ-BDC49406
SNOWFLAKE_USER=ANDYWALKMAN
SNOWFLAKE_ROLE=ACCOUNTADMIN
SNOWFLAKE_WAREHOUSE=COMPUTE_WH

# US Open Census (Marketplace) — from your connections.toml
SNOWFLAKE_DATABASE=US_OPEN_CENSUS_DATA__NEIGHBORHOOD_INSIGHTS__FREE_DATASET
SNOWFLAKE_SCHEMA=PUBLIC

# Auth — choose ONE:
# Option A: Personal Access Token (recommended for scripts & deployment)
SNOWFLAKE_PASSWORD=

# Option B: Browser SSO (local dev only; set SNOWFLAKE_AUTHENTICATOR=externalbrowser)
# SNOWFLAKE_AUTHENTICATOR=externalbrowser

# Data backend: duckdb (local snapshot) | snowflake (deploy / live)
DATA_BACKEND=duckdb
DUCKDB_PATH=data/census.duckdb
EMBEDDING_INDEX_PATH=data/field_embeddings.json
CENSUS_YEAR=2020
# Local DuckDB snapshots may only include 2019; the app auto-picks the newest
# vintage available in data/census.duckdb when the configured year is missing.

# LLM (Google Gemini — free tier: gemini-flash-latest)
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest
