# Snowflake connection (copy to .env and fill in secrets locally — never commit .env)

# Account identifier from Snowflake UI (Profile → Account)
SNOWFLAKE_ACCOUNT=EXLVOFZ-BDC49406
SNOWFLAKE_USER=ANDYWALKMAN
SNOWFLAKE_ROLE=ACCOUNTADMIN
SNOWFLAKE_WAREHOUSE=COMPUTE_WH

# US Open Census (Marketplace) — from your connections.toml
SNOWFLAKE_DATABASE=US_OPEN_CENSUS_DATA__NEIGHBORHOOD_INSIGHTS__FREE_DATASET
SNOWFLAKE_SCHEMA=PUBLIC

# Auth — choose ONE:
# Option A: Personal Access Token (recommended for scripts & deployment)
SNOWFLAKE_PASSWORD=

# Option B: Browser SSO (local dev only; set SNOWFLAKE_AUTHENTICATOR=externalbrowser)
# SNOWFLAKE_AUTHENTICATOR=externalbrowser

# --- LLM Provider (see docs/TECHNICAL_DESIGN.md §6.1) ---
# auto = try Cortex, then Ollama | ollama | cortex | openai
LLM_PROVIDER=ollama

# Cortex models (production — requires paid Snowflake account)
CORTEX_MODEL_FAST=claude-haiku-4-5
CORTEX_MODEL_MAIN=claude-sonnet-4-6
CORTEX_EMBED_MODEL=snowflake-arctic-embed-m

# Ollama (local dev — default for trial accounts)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL_FAST=qwen3.5:9b
OLLAMA_MODEL_MAIN=qwen3.6:27b
OLLAMA_EMBED_MODEL=qwen3-embedding:8b

# OpenAI (optional — for public deployment if needed)
OPENAI_API_KEY=
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_MODEL_MAIN=gpt-4o
OPENAI_EMBED_MODEL=text-embedding-3-small
